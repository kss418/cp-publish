  "kind_patterns": {
    "Educational": [
      "\\beducational\\s+codeforces\\s+round\\b"
    ],
    "Global": [
      "\\bcodeforces\\s+global\\s+round\\b"
    ],
    "regular": [
      "\\bcodeforces\\s+(?:beta\\s+)?round\\b",
      "\\bcodeforces\\s+alpha\\s+round\\b"
    ]
  },
  "round_number_patterns": {
    "Educational": [
      "\\beducational\\s+codeforces\\s+round\\s+#?(\\d+)\\b"
    ],
    "Global": [
      "\\bcodeforces\\s+global\\s+round\\s+#?(\\d+)\\b"
    ],
    "regular": [
      "\\bcodeforces\\s+(?:beta\\s+)?round\\s+#?(\\d+)\\b",
      "\\bcodeforces\\s+alpha\\s+round\\s+#?(\\d+)\\b"
    ],
    "Others": {
      "Kotlin_Heroes": [
        "\\bkotlin\\s+heroes\\s+(\\d+)\\s*:",
        "\\bkotlin\\s+heroes:\\s*(?:episode|practice)\\s+(\\d+)\\b"
      ],
      "April_Fools": [
        "\\bapril\\s+fools(?:\\s+day)?\\s+contest\\s+#?(\\d{1,3})\\b"
      ],
      "Testing_Round": [
        "\\b(?:codeforces\\s+)?testing\\s+round\\s+#?(\\d+)\\b"
      ],
      "School_Team_Contest": [
        "\\bschool\\s+team\\s+contest\\s+#?(\\d+)\\b"
      ],
      "ICPC_World_Finals_Challenge": [
        "\\b(\\d+)(?:st|nd|rd|th)\\s+icpc\\s+world\\s+finals\\s+challenge\\b"
      ],
      "BOI": [
        "\\bbaltic\\s+olympiad\\s+in\\s+informatics\\s+(?:19|20)(\\d{2})\\b"
      ],
      "CEOI": [
        "\\bceoi\\s+(?:19|20)(\\d{2})\\b",
        "\\bcentral[-\\s]+european\\s+olympiad\\s+in\\s+informatics\\b.*\\b(?:19|20)(\\d{2})\\b"
      ],
      "Manthan_Codefest_16": [
        "\\bmanthan\\b.*\\bcodefest\\s+(\\d+)\\b"
      ],
      "Manthan_Codefest_17": [
        "\\bmanthan\\b.*\\bcodefest\\s+(\\d+)\\b"
      ],
      "Manthan_Codefest_18": [
        "\\bmanthan\\b.*\\bcodefest\\s+(\\d+)\\b"
      ],
      "Manthan_Codefest_19": [
        "\\bmanthan\\b.*\\bcodefest\\s+(\\d+)\\b"
      ],
      "*": [
        "\\bround\\s+#?(\\d+)\\b"
      ],
      "_year_suffix": [
        "\\b(?:hello|good\\s+bye|goodbye)\\s+((?:19|20)\\d{2})\\b",
        "\\bapril\\s+fools(?:\\s+day)?\\s+contest\\s+((?:19|20)\\d{2})\\b",
        "\\b((?:19|20)\\d{2})\\b"
      ]
    }
  },
